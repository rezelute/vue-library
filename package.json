{
   "name": "@rezelute/vue-library",
   "version": "1.0.2",
   "type": "module",
   "types": "./dist/index.d.ts",
   "sideEffects": [
      "**/*.vue",
      "**/*.css"
   ],
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js"
      },
      "./components": {
         "types": "./dist/components/index.d.ts",
         "import": "./dist/components/index.js"
      },
      "./stores": {
         "types": "./dist/stores/index.d.ts",
         "import": "./dist/stores/index.js"
      },
      "./composables": {
         "types": "./dist/composables/index.d.ts",
         "import": "./dist/composables/index.js"
      },
      "./utils": {
         "types": "./dist/utils/index.d.ts",
         "import": "./dist/utils/index.js"
      },
      "./content": {
         "types": "./dist/content/index.d.ts",
         "import": "./dist/content/index.js"
      },
      "./types": {
         "types": "./dist/types/index.d.ts"
      },
      "./tailwind.css": {
         "default": "./dist/tailwind.css"
      },
      "./tailwind-setup.css": {
         "default": "./dist/tailwind-setup.css"
      },
      "./tailwind-utilities.css": {
         "default": "./dist/tailwind-utilities.css"
      },
      "./vue-library.css": {
         "default": "./dist/vue-library.css"
      }
   },
   "files": [
      "dist",
      "src"
   ],
   "scripts": {
      "dev": "vite",
      "build": "run-p tscheck \"build-only {@}\" --",
      "build-w-types": "run-s generate-types build-only",
      "generate-types": "vue-tsc --build tsconfig.build.json",
      "build-only": "vite build",
      "build-watch": "vite build --watch",
      "build-pack": "npm run build && npm pack",
      "preview": "vite preview",
      "--TESTING--": "",
      "test:unit": "vitest",
      "--PROJECT--": "",
      "tscheck": "vue-tsc --build",
      "lint": "eslint . --fix",
      "prettier": "prettier --check src/",
      "prettier-fix": "prettier --write src/",
      "storybook": "storybook dev -p 6006",
      "build-storybook": "storybook build"
   },
   "peerDependencies": {
      "@primeuix/themes": "^2.0.1",
      "@tailwindcss/vite": "^4.0.0",
      "pinia": "^3.0.0",
      "primeicons": "^7.0.0",
      "primevue": "^4.5.0",
      "tailwindcss": "^4.0.0",
      "tailwindcss-primeui": "^0.6.1",
      "vee-validate": "^4.0.0",
      "vue": "^3.5.25",
      "zod": "^4.1.5"
   },
   "devDependencies": {
      "@chromatic-com/storybook": "^5.2.1",
      "@storybook/addon-a11y": "^10.4.6",
      "@storybook/addon-docs": "^10.4.6",
      "@storybook/addon-onboarding": "^10.4.6",
      "@storybook/addon-vitest": "^10.4.6",
      "@storybook/vue3-vite": "^10.4.6",
      "@tsconfig/node22": "^22.0.5",
      "@types/jsdom": "^28.0.3",
      "@types/node": "^26.0.0",
      "@vitejs/plugin-vue": "^6.0.7",
      "@vitest/browser-playwright": "^4.1.9",
      "@vitest/coverage-v8": "^4.1.9",
      "@vitest/eslint-plugin": "^1.6.20",
      "@vue/eslint-config-prettier": "^10.1.0",
      "@vue/eslint-config-typescript": "^14.9.0",
      "@vue/language-core": "^3.3.5",
      "@vue/test-utils": "^2.4.11",
      "@vue/tsconfig": "^0.9.0",
      "dotenv": "^17.4.2",
      "eslint": "^10.5.0",
      "eslint-plugin-simple-import-sort": "^13.0.0",
      "eslint-plugin-storybook": "^10.4.6",
      "eslint-plugin-vue": "^10.9.2",
      "jiti": "^2.7.0",
      "jsdom": "^29.1.1",
      "npm-run-all2": "^9.0.2",
      "playwright": "^1.61.0",
      "prettier": "^3.8.4",
      "primevue": "^4.5.5",
      "rollup-plugin-copy": "^3.5.0",
      "storybook": "^10.4.6",
      "tailwindcss": "^4.3.1",
      "typescript": "^6.0.3",
      "vite": "^8.0.16",
      "vite-plugin-dts": "^5.0.2",
      "vitest": "^4.1.9",
      "vue": "^3.5.38",
      "vue-eslint-parser": "^10.4.1",
      "vue-tsc": "^3.3.5",
      "zod": "^4.4.3"
   }
}
