{
   "name": "@rezelute/vue-library",
   "version": "1.0.2",
   "private": true,
   "type": "module",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "import": "./dist/index.js",
         "types": "./dist/index.d.ts"
      },
      "./components": {
         "import": "./dist/components/index.js",
         "types": "./dist/components/index.d.ts"
      },
      "./stores": {
         "import": "./dist/stores/index.js",
         "types": "./dist/stores/index.d.ts"
      },
      "./composables": {
         "import": "./dist/composables/index.js",
         "types": "./dist/composables/index.d.ts"
      },
      "./utils": {
         "import": "./dist/utils/index.js",
         "types": "./dist/utils/index.d.ts"
      },
      "./content": {
         "import": "./dist/content/index.js",
         "types": "./dist/content/index.d.ts"
      },
      "./types": {
         "import": "./dist/types/index.js",
         "types": "./dist/types/index.d.ts"
      },
      "./tailwind-config.css": {
         "default": "./dist/tailwind-config.css"
      },
      "./vue-library.css": {
         "default": "./dist/vue-library.css"
      }
   },
   "files": [
      "dist"
   ],
   "prepare": "vite build",
   "scripts": {
      "dev": "vite",
      "build": "run-p tscheck \"build-only {@}\" --",
      "build-w-types": "run-s generate-types build-only",
      "generate-types": "vue-tsc --build tsconfig.build.json",
      "build-only": "vite build",
      "build-watch": "vite build --watch",
      "build-pack": "npm run build && npm pack",
      "preview": "vite preview",
      "--TESTING--": "",
      "test:unit": "vitest",
      "--PROJECT--": "",
      "tscheck": "vue-tsc --build",
      "lint": "eslint . --fix",
      "prettier": "prettier --check src/",
      "prettier-fix": "prettier --write src/",
      "stylelint": "stylelint \"**/*.scss\" \"**/*.vue\"",
      "stylelint-fix": "stylelint \"**/*.scss\" \"**/*.vue\" --fix",
      "storybook": "storybook dev -p 6006",
      "build-storybook": "storybook build"
   },
   "peerDependencies": {
      "@primeuix/themes": "^2.0.1",
      "@tailwindcss/vite": "^4.0.0",
      "pinia": "^3.0.0",
      "primeicons": "^7.0.0",
      "primevue": "^4.5.0",
      "tailwindcss": "^4.0.0",
      "tailwindcss-primeui": "^0.6.1",
      "vee-validate": "^4.0.0",
      "vue": "^3.5.25",
      "zod": "^4.1.5"
   },
   "devDependencies": {
      "@chromatic-com/storybook": "^4.1.3",
      "@storybook/addon-a11y": "^10.1.11",
      "@storybook/addon-docs": "^10.1.11",
      "@storybook/addon-onboarding": "^10.1.11",
      "@storybook/addon-vitest": "^10.1.11",
      "@storybook/vue3-vite": "^10.1.11",
      "@tsconfig/node22": "^22.0.5",
      "@types/jsdom": "^27.0.0",
      "@types/node": "^24.10.1",
      "@vitejs/plugin-vue": "^6.0.2",
      "@vitest/browser-playwright": "^4.0.14",
      "@vitest/coverage-v8": "^4.0.14",
      "@vitest/eslint-plugin": "^1.5.0",
      "@vue/eslint-config-prettier": "^10.1.0",
      "@vue/eslint-config-typescript": "^14.5.0",
      "@vue/test-utils": "^2.4.6",
      "@vue/tsconfig": "^0.8.1",
      "dotenv": "^17.2.3",
      "eslint": "^9.39.1",
      "eslint-plugin-simple-import-sort": "^12.1.1",
      "eslint-plugin-storybook": "^10.1.11",
      "eslint-plugin-vue": "^10.6.1",
      "jiti": "^2.6.1",
      "jsdom": "^27.2.0",
      "npm-run-all2": "^8.0.4",
      "playwright": "^1.57.0",
      "prettier": "^3.7.1",
      "primevue": "^4.5.0",
      "rollup-plugin-copy": "^3.5.0",
      "sass": "^1.94.2",
      "storybook": "^10.1.11",
      "stylelint": "^16.26.0",
      "stylelint-config-recess-order": "^7.4.0",
      "stylelint-config-standard": "^39.0.1",
      "stylelint-config-standard-scss": "^16.0.0",
      "stylelint-config-standard-vue": "^1.0.0",
      "tailwindcss": "^4.1.17",
      "typescript": "^5.9.3",
      "vite": "^7.2.4",
      "vite-plugin-dts": "^4.5.3",
      "vitest": "^4.0.14",
      "vue": "^3.5.25",
      "vue-eslint-parser": "^10.1.1",
      "vue-tsc": "^3.1.5",
      "zod": "^4.1.13"
   }
}
